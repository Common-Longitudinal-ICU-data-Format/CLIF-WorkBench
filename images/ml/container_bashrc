# clif-workbench:ml — Container shell configuration

# --- Prompt ---
export PS1='\[\033[1;36m\][clif-ml]\[\033[0m\] \[\033[1;33m\]\w\[\033[0m\] \$ '

# --- Aliases ---
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias py='python'

# --- Python ---
export PYTHONDONTWRITEBYTECODE=1
export PYTHONUNBUFFERED=1

# --- uv shell completion ---
eval "$(uv generate-shell-completion bash 2>/dev/null)"
